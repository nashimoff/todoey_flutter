# ──────────────────────────────────────────
# Miscellaneous
# ──────────────────────────────────────────
*.class
*.log
*.pyc
*.swp
.DS_Store
*.zip

# ──────────────────────────────────────────
# IDE — all ignored so no one's settings
# overwrite anyone else's
# ──────────────────────────────────────────
.idea/
*.iml
*.ipr
*.iws
.vscode/
.atom/
.history

# ──────────────────────────────────────────
# Flutter / Dart / Pub
# ──────────────────────────────────────────
**/doc/api/
.dart_tool/
.flutter-plugins
.flutter-plugins-dependencies
.packages
.pub-cache/
.pub/
/build/

# ──────────────────────────────────────────
# Android
# Each machine uses its own local Gradle,
# so wrapper files are excluded entirely.
# ──────────────────────────────────────────
**/android/.gradle/
**/android/build/
**/android/captures/
**/android/local.properties
**/android/**/GeneratedPluginRegistrant.java

# Gradle wrapper — excluded because every
# machine/CI already has Gradle installed
**/android/gradle/
**/android/gradlew
**/android/gradlew.bat
**/android/gradle.properties

# ──────────────────────────────────────────
# iOS / Xcode
# ──────────────────────────────────────────
**/ios/**/*.mode1v3
**/ios/**/*.mode2v3
**/ios/**/*.moved-aside
**/ios/**/*.pbxuser
**/ios/**/*.perspectivev3
**/ios/**/*sync/
**/ios/**/.sconsign.dblite
**/ios/**/.tags*
**/ios/**/DerivedData/
**/ios/**/Icon?
**/ios/**/Pods/
**/ios/**/.symlinks/
**/ios/**/xcuserdata
**/ios/.generated/
**/ios/Flutter/App.framework
**/ios/Flutter/Flutter.framework
**/ios/Flutter/Generated.xcconfig
**/ios/Flutter/app.flx
**/ios/Flutter/app.zip
**/ios/Flutter/flutter_assets/
**/ios/ServiceDefinitions.json
**/ios/Runner/GeneratedPluginRegistrant.*

# Exceptions — keep default Xcode scheme files
!**/ios/**/default.mode1v3
!**/ios/**/default.mode2v3
!**/ios/**/default.pbxuser
!**/ios/**/default.perspectivev3